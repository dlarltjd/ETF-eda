# ==========================================
# Python & Virtual Environments (가상 환경)
# ==========================================
.venv/
venv/
env/
ENV/

# Byte-compiled / 파이썬 바이트코드 캐시
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Data Files (수집된 데이터 파일)
# ==========================================
data/*.csv
data/*.xlsx
!data/.gitkeep
!data/etf_latest.json
!data/etf_data_*.json
!data/etf_data_*.csv

# ==========================================
# Logs & Temporary Files (로그 및 임시 파일)
# ==========================================
*.log
*.tmp
*.temp

# ==========================================
# IDE & Operating System (개발 도구 및 OS 파일)
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db
.agents/

# ==========================================
# Streamlit & Agent Configs
# ==========================================
.streamlit/secrets.toml

